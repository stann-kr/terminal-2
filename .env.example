# =====================================================
# TERMINAL — 환경변수 템플릿
# 실제 값은 .env.local에 작성하고 절대 커밋하지 말 것
# =====================================================

# Cloudflare Workers 배포 인증
# 발급: https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# D1 데이터베이스 바인딩은 wrangler.toml에서 설정됨
# [[d1_databases]]
# binding = "DB"
# database_name = "terminal-2-db"
# database_id = "<wrangler d1 create 실행 후 발급된 ID>"
